# Frontend runtime variables.
# These are injected into the browser bundle by Vite and are therefore PUBLIC at runtime.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_GOOGLE_MAPS_API_KEY=google_maps_browser_key_with_http_referrer_restrictions

# Local/private variables for scripts only.
# Never prefix private values with VITE_.
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_ACCESS_TOKEN=your_personal_access_token_for_local_scripts_only
